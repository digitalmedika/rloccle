# OpenAI API Key (required for standard OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Model name (defaults to openai/gpt-4o if not specified in code or env)
# OPENAI_MODEL=openai/gpt-4o
# AGENT_MODEL=openai/gpt-4o

# Optional: Custom base URL (e.g. for LocalAI, Ollama, LM Studio, or OpenRouter)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_BASE=https://api.openai.com/v1
